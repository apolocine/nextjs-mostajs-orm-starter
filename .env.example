# Développement / déploiement Node (données durables)
DB_DIALECT=sqlite          # better-sqlite3 (binaire natif)
DATABASE_URL=./blog.db     # fichier persistant
NODE_ENV=development

# Pour le navigateur / Bolt.new / WebContainer, utiliser plutôt :
#   DB_DIALECT=sqljs         # SQLite WASM, zéro binaire natif
#   DATABASE_URL=:memory:    # in-memory (seed-on-boot rejoue)
# (réglé automatiquement par .stackblitzrc dans StackBlitz/Bolt)

# Seed automatique au démarrage (anti-page-vide). Mettre 0 en prod.
ORM_SEED_ON_BOOT=1
